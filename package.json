{
  "name": "fetchwave",
  "productName": "Fetchwave",
  "version": "1.0.0-rc.7",
  "description": "A premium desktop downloader for the open web. Fast, modern, and built on yt-dlp.",
  "author": {
    "name": "Fetchwave",
    "email": "hello@fetchwave.app"
  },
  "homepage": "https://github.com/quanb24/fetchwave",
  "repository": {
    "type": "git",
    "url": "https://github.com/quanb24/fetchwave"
  },
  "bugs": {
    "url": "https://github.com/quanb24/fetchwave/issues"
  },
  "license": "MIT",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "vite",
    "lint": "tsc --noEmit",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "npm run lint && npm run build:main && npm run build:renderer",
    "fetch:bin": "bash scripts/fetch-binaries.sh",
    "fetch:bin:win": "powershell -ExecutionPolicy Bypass -File scripts/fetch-binaries.ps1",
    "package": "npm run build && electron-builder",
    "package:mac": "npm run build && electron-builder --mac --arm64 --x64",
    "package:win": "npm run build && electron-builder --win --x64",
    "package:linux": "npm run build && electron-builder --linux --x64",
    "publish": "npm run build && electron-builder --publish always",
    "publish:mac": "npm run build && electron-builder --mac --arm64 --x64 --publish always",
    "publish:win": "npm run build && electron-builder --win --x64 --publish always",
    "release:patch": "npm version patch && git push && git push --tags",
    "release:minor": "npm version minor && git push && git push --tags",
    "release:major": "npm version major && git push && git push --tags",
    "release:rc": "npm version prerelease --preid=rc && git push && git push --tags",
    "start": "electron ."
  },
  "dependencies": {
    "electron-log": "^5.1.5",
    "electron-updater": "^6.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "app.fetchwave.desktop",
    "productName": "Fetchwave",
    "copyright": "Copyright © 2026 Fetchwave",
    "artifactName": "Fetchwave-${version}-${os}-${arch}.${ext}",
    "generateUpdatesFilesForAllChannels": true,
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "!resources/bin/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/bin/${os}/${arch}",
        "to": "bin/${os}/${arch}",
        "filter": [
          "**/*"
        ]
      }
    ],
    "extraMetadata": {
      "main": "dist-electron/main/index.js"
    },
    "asar": true,
    "asarUnpack": [
      "**/node_modules/**/*.node"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "darkModeSupport": true
    },
    "dmg": {
      "title": "${productName} ${version}",
      "writeUpdateInfo": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Fetchwave",
      "uninstallDisplayName": "Fetchwave",
      "deleteAppDataOnUninstall": false,
      "differentialPackage": true,
      "menuCategory": false,
      "runAfterFinish": true
    },
    "linux": {
      "category": "Network",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "maintainer": "hello@fetchwave.app",
      "synopsis": "Premium desktop downloader for the open web",
      "description": "Fetchwave is a fast, modern desktop app for downloading video and audio from the open web, powered by yt-dlp."
    },
    "publish": [
      {
        "provider": "github",
        "owner": "quanb24",
        "repo": "fetchwave",
        "releaseType": "release"
      }
    ]
  }
}
